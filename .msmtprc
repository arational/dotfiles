defaults
auth            on
tls             on
tls_trust_file  /etc/ssl/certs/ca-certificates.crt
logfile         ~/.msmtp.log

# personal
account         personal
host            smtp.1und1.de
port            587
from            ivan@stefanischin.eu
user            ivan@stefanischin.eu
passwordeval    pass email/ivan@stefanischin.eu

# gmail
account         gmail
host            smtp.gmail.com
port            587
from            mattajhana@gmail.com
user            mettajhana@gmail.com
passwordeval    pass email/mettajhana@gmail.com

# spam
account         spam
host            smtp.1und1.de
port            587
from            katzomoto@online.de
user            katzomoto@online.de
passwordeval    pass email/katzomoto@online.de

# bevuta
account         bevuta
host            mail.networkname.de
port            587
from            ivan.stefanischin@bevuta.com
user            ivan.stefanischin@bevuta.com
passwordeval    pass email/ivan.stefanischin@bevuta.com

# stefanischin
account         stefanischin
host            smtp.1und1.de
port            587
from            3013-614@online.de
user            3013-614@online.de
passwordeval    pass email/3013-614@online.de

account default : personal
