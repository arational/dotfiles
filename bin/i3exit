#!/bin/sh
lock() {
   i3lock -c 000000 -e -u
}

case "$1" in
   lock)
       sudo tomb close
       lock
       ;;
   logout)
       sudo tomb close
       i3-msg exit
       ;;
   suspend)
       sudo tomb close
       lock && systemctl suspend
       ;;
   hibernate)
       sudo tomb close
       lock && systemctl hibernate
       ;;
   reboot)
       sudo tomb close
       systemctl reboot
       ;;
   shutdown)
       sudo tomb close
       systemctl poweroff
       ;;
   *)
       echo "Usage: $0 {lock|logout|suspend|hibernate|reboot|shutdown}"
       exit 2
esac

exit 0
