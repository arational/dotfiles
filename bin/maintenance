#!/bin/sh
BACKUPDIR=$HOME/var/backup/liquid
SAVEDIR=$HOME/mnt/nas/backup/

backup() {
    TARGETDIR=$BACKUPDIR/$(date +%Y%m%d)
    DOTFILES=$(ls -a | grep -E "^\.[^\.]+")
    BINDIR=$HOME/bin
    EXCDOTFILES=".cache .thunderbird .m2"

    for ITEM in $EXCDOTFILES
    do
        DOTFILES=$(echo "$DOTFILES" | grep -v "$ITEM")
    done

    mkdir -p $TARGETDIR

    PACMAN=$TARGETDIR/pacman
    mkdir -p $PACMAN
    pacman -Qqen > $PACMAN/pkglist_native
    pacman -Qqem > $PACMAN/pkglist_foreign

    cd /usr/local/
    tar -cjf $TARGETDIR/usr-local.tar.bz2 *

    cd /var/lib/pacman/local/
    tar -cjf $PACMAN/local.tar.bz2 *

    cd /etc/
    tar -cjf $TARGETDIR/etc.tar.bz2 *

    cd $HOME
    tar -cjf $TARGETDIR/dotfiles.tar.bz2 $DOTFILES

    cd $BINDIR
    tar -cjf $TARGETDIR/bin.tar.bz2 *
}

cleanup() {
    obsolete_pkgs=$(pacman -Qtdq)
    if [ -n "$obsolete_pkgs" ]; then
        sudo pacman -Rns $obsolete_pkgs
    fi
    sudo pacman -Sc
}

save_backups() {
    if [ ! -d "$SAVEDIR" ]; then
        echo "ERROR: directory \"$SAVEDIR\" does not exist."
        exit 1
    fi

    echo "Saving \"$BACKUPDIR\" ..."
    cp -r -n "$BACKUPDIR" "$SAVEDIR" || true

    echo "Pushing password-store ..."
    pass git push
}

case "$1" in
    failed)
        systemctl --failed --all
        ;;
    errors)
        journalctl -p 3 -xb
        ;;
    installed)
        pacman -Qne
        pacman -Qme
        ;;
    backup)
        backup
        ;;
    save_backups)
        save_backups
        ;;
    upgrade)
        backup
        sudo pacman -Syu
        ;;
    sync)
        sudo pacman -Sy
        ;;
    cleanup)
        cleanup
        ;;
    *)
        echo "Usage: $0 {failed|errors|installed|foreign|cleanup}"
        echo "failed       - Show all failed units during boot time."
        echo "errors       - Show system errors."
        echo "installed    - Show manually installed packages."
        echo "backup       - Make backup of the current system."
        echo "save_backups - Save all backups to remote server."
        echo "upgrade      - Make backup and upgrade the current system."
        echo "sync         - Sync package database."
        echo "cleanup      - Remove packages that maybe not needed anymore."
        exit 2
esac

exit 0
