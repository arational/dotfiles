#!/bin/sh
BACKUPDIR=$HOME/var/backup/$HOSTNAME/fast
SAVEDIR=$HOME/mnt/nas/backup/$HOSTNAME
PACKAGECACHE=/var/cache/pacman/pkg

confirm () {
    while true
    do
        read -p "Continue (y/n)? " answer
        case "$answer" in
            y|Y) return 0;;
            n|N) return 1;;
        esac
    done
}

backup() {
    TARGETDIR=$BACKUPDIR/$(date +%Y%m%d)
    DOTFILES=$(ls -a | grep -E "^\.[^\.]+")
    BINDIR=$HOME/bin
    DOTFILEBLACKLIST="$(cat $HOME/.config/maintenance/dotfile_blacklist)"

    mkdir -p "$BACKUPDIR"

    for ITEM in $DOTFILEBLACKLIST
    do
        DOTFILES=$(echo "$DOTFILES" | grep -v "$ITEM")
    done

    mkdir -p $TARGETDIR

    PACMAN=$TARGETDIR/pacman
    mkdir -p $PACMAN
    pacaur -Qqen > $PACMAN/pkglist_native
    pacaur -Qqem > $PACMAN/pkglist_foreign

    echo "Making backup for /usr/local ..."
    cd /usr/local/
    tar -cjf $TARGETDIR/usr-local.tar.bz2 *

    echo "Making backup for /var/lib/pacman/local ..."
    cd /var/lib/pacman/local/
    tar -cjf $PACMAN/local.tar.bz2 *

    echo "Making backup for /etc ..."
    cd /etc/
    sudo tar -cjf $TARGETDIR/etc.tar.bz2 * && \
    sudo chown $USER:users $TARGETDIR/etc.tar.bz2

    echo "Making backup for home dotfiles ..."
    cd $HOME
    tar -cjf $TARGETDIR/dotfiles.tar.bz2 $DOTFILES

    echo "Making backup for home bindir ..."
    cd $BINDIR
    tar -cjf $TARGETDIR/bin.tar.bz2 *

    echo "Done!"
}

cleanup() {
    DOWNLOADDIR=$HOME/var/downloads

    obsolete_pkgs=$(pacaur -Qtdq)
    if [ -n "$obsolete_pkgs" ]; then
        echo "Removing obsolete packages ..."
        pacaur -Rns $obsolete_pkgs
    fi

    echo "Deleting temporary backups ..."
    confirm && rm -r $BACKUPDIR/*

    echo "Deleting package cache ..."
    pacaur -Sc

    echo "Deleting temporary downloads ..."
    confirm && rm -r $DOWNLOADDIR/* &> /dev/null

    echo "Deleting temporary files ..."
    confirm && rm -r $HOME/tmp/* &> /dev/null

    echo "Done!"
}

save_backups() {
    if [ ! -d "$SAVEDIR" ]; then
        echo "ERROR: directory \"$SAVEDIR\" does not exist."
        exit 1
    fi

    echo "Saving \"$BACKUPDIR\" ..."
    cp -r -n "$BACKUPDIR" "$SAVEDIR"

    echo "Saving package cache ..."
    cp -r -n "$PACKAGECACHE" "$SAVEDIR/"

    echo "Pushing password-store ..."
    sudo tomb open -g -f $HOME/.password.tomb -k $HOME/.password.tomb.key $HOME/.password-store/
    pass git pull
    pass git push
    sudo tomb close

    echo "Pushing dotfiles ..."
    cd $HOME
    git pull
    git push

    echo "Done!"
}

case $1 in
    failed)
        systemctl --failed --all
        ;;
    errors)
        journalctl -p 3 -xb
        ;;
    installed)
        pacaur -Qne
        pacaur -Qme
        ;;
    backup)
        backup
        ;;
    save_backups)
        save_backups
        ;;
    upgrade)
        pacaur -Syu
        ;;
    sync)
        pacaur -Sy
        ;;
    cleanup)
        cleanup
        ;;
    custom_pkgs)
        expac "%n %p" | grep "Ivan Stefanischin" | column -t
        ;;
    *)
        echo "Usage: $0 {failed|errors|installed|foreign|cleanup}"
        echo "failed       - Show all failed units during boot time."
        echo "errors       - Show system errors."
        echo "installed    - Show manually installed packages."
        echo "backup       - Make backup of the current system."
        echo "save_backups - Save all backups to remote server."
        echo "upgrade      - Make backup, upgrade the system and do a cleanup."
        echo "sync         - Sync package database."
        echo "cleanup      - Does some cleanup work and asks for confirmation"
        echo "               before every step."
        echo "custom_pkgs  - Show manually compiled packages."
        exit 2
esac
