#!/bin/sh

BAT=0
RDY_PERC=75
FULL_PERC=95

DEFAULT_START=40
DEFAULT_STOP=80

# set the battery charging thresholds to extend battery lifespan
set_thresh() {
    echo $2 | sudo tee /sys/devices/platform/smapi/BAT$1/start_charge_thresh > /dev/null
    echo $3 | sudo tee /sys/devices/platform/smapi/BAT$1/stop_charge_thresh > /dev/null
}

case "$1" in
    prepare)
        set_thresh $BAT $RDY_PERC $DEFAULT_STOP
        ;;
    ready)
        set_thresh $BAT $DEFAULT_START $DEFAULT_STOP
        ;;
    full)
        set_thresh $BAT $FULL_PERC $FULL_PERC
        ;;
    *)
        echo "Usage: $0 {prepare|ready}"
        echo "prepare - charge battery until a percentage of $RDY_PERC is reached."
        echo "ready   - set battery charge percentage threshold to $DEFAULT_START - $DEFAULT_STOP."
        echo "full    - set battery charge percentage threshold to $FULL_PERC."
esac
